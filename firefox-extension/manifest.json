{
  "manifest_version": 2,
  "name": "wearebaked",
  "version": "0.2.0",
  "description": "See who your browser is talking to. A simple network traffic dashboard for everyone.",
  "permissions": [
    "webRequest",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "wearebaked@extension",
      "strict_min_version": "109.0"
    }
  }
}
