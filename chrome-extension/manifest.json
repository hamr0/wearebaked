{
  "manifest_version": 3,
  "name": "wearebaked",
  "version": "0.5.1",
  "description": "See who your browser is talking to — and who's selling your data.",
  "permissions": [
    "webRequest",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
