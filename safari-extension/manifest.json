{
  "manifest_version": 2,
  "name": "wearebaked",
  "version": "0.5.0",
  "description": "See who your browser is talking to — and who's selling your data.",
  "permissions": [
    "webRequest",
    "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
