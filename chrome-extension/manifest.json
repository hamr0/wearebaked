{
  "manifest_version": 3,
  "name": "wearebaked",
  "version": "0.2.0",
  "description": "See who your browser is talking to. A simple network traffic dashboard for everyone.",
  "permissions": [
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
